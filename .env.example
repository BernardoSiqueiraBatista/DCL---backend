# =================================
# SERVER
# =================================
PORT=3000
NODE_ENV=development

# =================================
# DATABASE (PostgreSQL / Supabase)
# =================================
# Opção A — Postgres local (docker-compose):
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dcl_db
DB_USER=dcl_user
DB_PASS=dcl_password
DB_SSL=false

# Opção B — Supabase: defina DATABASE_URL com a connection string do projeto
# (Supabase Dashboard → Project Settings → Database → Connection string → "URI",
#  de preferência o pooler na porta 6543). Quando presente, tem precedência sobre
#  os DB_* acima e o SSL é ligado automaticamente.
# DATABASE_URL=postgresql://postgres.<ref>:<DB_PASSWORD>@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# =================================
# SUPABASE (REST / Storage) — opcional
# =================================
# SUPABASE_URL=https://<ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
# SUPABASE_STORAGE_BUCKET=project-creatives

# =================================
# JWT
# =================================
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# =================================
# GMAIL SMTP (OTP)
# Gere uma App Password em:
# https://myaccount.google.com/apppasswords
# (Requer 2FA ativado na conta Google)
# =================================
SMTP_USER=seuemail@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# =================================
# OTP
# =================================
OTP_EXPIRES_MINUTES=10

# =================================
# CORS
# =================================
CORS_ORIGIN=http://localhost:5173

# =================================
# LLM / GERAÇÃO DE IMAGENS (Tasks 6 e 7)
# Sem OPENAI_API_KEY, o backend usa um gerador MOCK determinístico
# (suficiente para validar layout/fluxo offline).
# =================================
# OPENAI_API_KEY=sk-...
LLM_TEXT_MODEL=gpt-4o-mini
IMAGE_MODEL=dall-e-3
REGENERATE_COOLDOWN_HOURS=6

# =================================
# UPLOADS (referências gráficas — Task 6)
# =================================
UPLOAD_DIR=uploads
UPLOAD_MAX_MB=10
UPLOAD_MAX_FILES=5

# =================================
# SEED (dados mockados — npm run seed)
# =================================
SEED_EMAIL=demo@dclab.com
SEED_PASSWORD=Demo1234
